cat("\n\n")
cat("========== REGRESSION 7: LOG BONDED DEBT - YEAR 1 EFFECT ==========\n")
reg7_data <- analysis_data %>%
filter(!is.na(log_bonded_debt))
cat(paste("Observations:", nrow(reg7_data), "\n"))
cat(paste("Company-events:", n_distinct(reg7_data$CompanyCountyEvent_ID), "\n"))
cat(paste("Counties:", n_distinct(paste(reg7_data$county_clean, reg7_data$state_clean)), "\n"))
cat(paste("Years:", paste(range(reg7_data$Year), collapse = " to "), "\n\n"))
cat("Summary Statistics:\n")
summary_reg7 <- reg7_data %>%
summarise(
Variable = c("log_bonded_debt", "PostYear"),
N = c(sum(!is.na(log_bonded_debt)), sum(!is.na(PostYear))),
Mean = c(mean(log_bonded_debt, na.rm = TRUE), mean(PostYear, na.rm = TRUE)),
SD = c(sd(log_bonded_debt, na.rm = TRUE), sd(PostYear, na.rm = TRUE)),
Min = c(min(log_bonded_debt, na.rm = TRUE), min(PostYear, na.rm = TRUE)),
Max = c(max(log_bonded_debt, na.rm = TRUE), max(PostYear, na.rm = TRUE)),
PostYear_1 = c(NA, sum(PostYear == 1, na.rm = TRUE)),
PostYear_0 = c(NA, sum(PostYear == 0, na.rm = TRUE))
)
print(summary_reg7)
cat("\n")
cat("Running TWFE regression...\n")
model_7 <- feols(
log_bonded_debt ~ PostYear | CompanyCountyEvent_ID + Year,
data = reg7_data,
cluster = ~ CompanyCountyEvent_ID
)
cat("\nResults:\n")
summary(model_7)
cat("\n\n")
