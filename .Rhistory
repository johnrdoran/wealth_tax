pvalue(model_5)["PostYear"],
pvalue(model_6)["Post2Year"],
pvalue(model_7)["PostYear"],
pvalue(model_8)["Post2Year"]
),
Adj_R2 = c(
r2(model_1, type = "ar2"),
r2(model_2, type = "ar2"),
